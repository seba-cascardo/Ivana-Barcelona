; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters
;
; Notas:
; - Este archivo es un esqueleto inicial. Al abrir por primera vez en
;   Godot 4 Editor, el editor puede normalizar/agregar campos.
; - Pixel-perfect rendering configurado: viewport 360x640 (PORTRAIT 9:16),
;   snap-to-pixel, filtro Nearest, scale_mode=integer. NO modificar sin
;   entender impacto.
; - Target real: phone-in-hand (portrait). 360x640 escala 3x a 1080x1920
;   (FHD portrait), 4x a 1440x2560 (QHD portrait). En phones 20:9 modernos
;   (ej. 1080x2400) hay leve letterbox vertical con aspect=keep.
; - window_*_override = 720x1280 (exacto 2x) para que en PC dev la ventana
;   sea portrait y simule el form factor del device. En mobile se ignora.

config_version=5

[application]

config/name="Ivana Barcelona"
config/description="Juego de detectives — homenaje moderno a Carmen Sandiego. Pixel art retro modernizado, narrativa Disco-Elysium-style."
config/version="0.0.1"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoloads/game_state.gd"

[display]

window/size/viewport_width=360
window/size/viewport_height=640
window/size/window_width_override=720
window/size/window_height_override=1280
window/size/resizable=true
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"
window/handheld/orientation="portrait"

[gui]

theme/default_font_subpixel_positioning=0

[internationalization]

locale/translations=PackedStringArray("res://localization/strings.csv")
locale/fallback="es"

[rendering]

textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
