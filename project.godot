; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters
;
; Notas:
; - Este archivo es un esqueleto inicial. Al abrir por primera vez en
;   Godot 4 Editor, el editor puede normalizar/agregar campos.
; - Pixel-perfect rendering configurado: viewport 640x360, snap-to-pixel,
;   filtro Nearest, scale_mode=integer. NO modificar sin entender impacto.
; - 640x360 escala 2x a 1280x720, 3x a 1920x1080, 4x a 2560x1440, 6x a 4K.
;   Sweet spot para pixel art con diálogos largos tipo Disco Elysium.
; - window_*_override = 1280x720 (exacto 2x) para que en PC siempre sea
;   16:9 perfecto sin black bars (1920x1080 no fitea limpio con la taskbar).
;   En mobile el override se ignora — la app es fullscreen del device.

config_version=5

[application]

config/name="Ivana Barcelona"
config/description="Juego de detectives — homenaje moderno a Carmen Sandiego. Pixel art retro modernizado, narrativa Disco-Elysium-style."
config/version="0.0.1"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoloads/game_state.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/size/resizable=true
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"
window/handheld/orientation=1

[gui]

theme/default_font_subpixel_positioning=0

[internationalization]

locale/translations=PackedStringArray("res://localization/strings.csv")
locale/fallback="es"

[rendering]

textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
